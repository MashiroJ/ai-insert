{
  "name": "ui-inspect-workspace",
  "version": "0.1.12",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "typecheck": "pnpm -r --filter './packages/*' run typecheck",
    "release:local": "node scripts/make-release.mjs",
    "publish:npm:dry-run": "node scripts/publish-npm.mjs",
    "publish:npm": "node scripts/publish-npm.mjs --yes"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "typescript": "^5.6.3",
    "vite": "^6.0.0"
  }
}
