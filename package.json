{
  "name": "ui-inspect-workspace",
  "version": "0.2.8",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' run build",
    "typecheck": "pnpm -r --filter './packages/*' run typecheck",
    "test": "vitest run",
    "check:versions": "node scripts/check-versions.mjs",
    "check:public-docs": "node scripts/check-public-docs.mjs",
    "check:release-clean": "node scripts/check-release-clean.mjs",
    "test:runtime-monitor": "node scripts/verify-runtime-monitor-integration.mjs",
    "release:local": "node scripts/make-release.mjs",
    "publish:npm:dry-run": "node scripts/publish-npm.mjs",
    "publish:npm": "node scripts/publish-npm.mjs --yes"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "playwright": "^1.60.0",
    "typescript": "^5.6.3",
    "vite": "^6.0.0",
    "vitest": "^4.1.7"
  }
}
