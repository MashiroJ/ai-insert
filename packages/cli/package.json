{
  "name": "@ui-inspect/cli",
  "version": "0.2.8",
  "type": "module",
  "bin": {
    "ui-inspect": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.test.*.map"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.24.0",
    "@ui-inspect/protocol": "workspace:*",
    "@ui-inspect/server": "workspace:*",
    "@ui-inspect/vite-plugin": "workspace:*",
    "jsonc-parser": "^3.3.1"
  }
}
