{
  "name": "@ui-inspect/shared",
  "version": "0.2.5",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./utils/performance": {
      "types": "./dist/utils/performance.d.ts",
      "import": "./dist/utils/performance.js"
    },
    "./utils/selector": {
      "types": "./dist/utils/selector.d.ts",
      "import": "./dist/utils/selector.js"
    },
    "./utils/validation": {
      "types": "./dist/utils/validation.d.ts",
      "import": "./dist/utils/validation.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "!dist/**/*.test.*.map"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "watch": "tsc --watch"
  },
  "dependencies": {
    "@ui-inspect/protocol": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
