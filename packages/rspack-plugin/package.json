{
  "name": "@ui-inspect/rspack-plugin",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!dist/**/*.test.*",
    "!src/**/*.test.*"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "watch": "tsc --watch"
  },
  "peerDependencies": {
    "@rspack/core": "^1.0.0"
  },
  "peerDependenciesMeta": {
    "@rspack/core": {
      "optional": true
    }
  },
  "dependencies": {
    "@ui-inspect/browser-ui": "workspace:*",
    "@ui-inspect/protocol": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
